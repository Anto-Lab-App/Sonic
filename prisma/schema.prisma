generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(cuid())
  clerkUserId String      @unique
  email       String
  credits     Int         @default(1)
  createdAt   DateTime    @default(now())
  diagnoses   Diagnosis[]
}

model Diagnosis {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  vehicleData String
  symptoms    String
  aiReport    Json
  createdAt   DateTime @default(now())
}
